# Required: Anthropic API key for the agent server
# Get your API key from https://console.anthropic.com/
# This overrides any user-level auth from ~/.claude/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the default VAPID subject for push notifications
# VAPID keys are auto-generated and stored in .beads/beads-app.db
VAPID_SUBJECT=mailto:admin@beadskanban.local
