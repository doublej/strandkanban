{
  "name": "strandkanban",
  "version": "0.4.1",
  "description": "Kanban board UI for the Beads issue tracker with drag-and-drop and agent integration",
  "type": "module",
  "files": [
    ".env.example",
    "README.md",
    "bin",
    "scheme",
    "scripts",
    "src",
    "static",
    "svelte.config.js",
    "tsconfig.json",
    "vite.config.ts"
  ],
  "bin": {
    "strandkanban": "./bin/bdk",
    "bdk": "./bin/bdk"
  },
  "scripts": {
    "dev": "vite dev --host",
    "dev:agent": "bun run src/lib/server/agent/index.ts & vite dev --host",
    "build": "vite build",
    "build:cli": "tsc --project bin/tsconfig.json",
    "prepare": "npm run build:cli",
    "prepublish": "npm run build:cli",
    "postinstall": "node scripts/postinstall.cjs || true",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.1.77",
    "@types/js-yaml": "^4.0.9",
    "@xyflow/svelte": "^1.6.1",
    "better-sqlite3": "^12.5.0",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "lucide-svelte": "^0.561.0",
    "marked": "^17.0.1",
    "web-push": "^3.6.7",
    "zod": "3.24.4"
  }
}
